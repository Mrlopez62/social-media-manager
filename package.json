{
  "name": "social-media-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:prelaunch": "node scripts/prelaunch-checklist.mjs",
    "test": "npm run test:integration",
    "test:integration": "node --test --experimental-strip-types \"tests/integration/*.test.ts\"",
    "test:integration:db": "node --test --experimental-strip-types \"tests/integration-db/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.57.4",
    "next": "15.5.14",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "22.13.4",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.14",
    "typescript": "5.9.3"
  }
}
